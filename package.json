{
  "name": "keddy",
  "version": "0.1.0",
  "description": "Session intelligence for Claude Code — navigable timelines, plan tracking, and past session search",
  "license": "Apache-2.0",
  "author": {
    "name": "Emir Enes Aksay",
    "email": "emire.aksay@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emireaksay-8867/keddy.git"
  },
  "homepage": "https://github.com/emireaksay-8867/keddy#readme",
  "bugs": "https://github.com/emireaksay-8867/keddy/issues",
  "keywords": [
    "claude-code",
    "session-intelligence",
    "plan-tracking",
    "ai-coding",
    "developer-tools",
    "mcp",
    "claude",
    "session-history"
  ],
  "bin": {
    "keddy": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": [
    "dist",
    ".claude-plugin",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0 <24.0.0"
  },
  "scripts": {
    "build": "tsup && npm run build:dashboard",
    "build:cli": "tsup",
    "build:dashboard": "vite build",
    "dev": "concurrently \"tsup --watch\" \"tsx watch src/dashboard/server-dev.ts\" \"vite dev\"",
    "dev:dashboard": "vite dev",
    "dev:server": "tsx watch src/dashboard/server-dev.ts",
    "dev:reimport": "tsx src/cli/index.ts reimport",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.10.0",
    "geist": "^1.7.0",
    "hono": "^4.6.0",
    "lucide-react": "^1.0.1",
    "open": "^10.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "dotenv": "^17.3.1",
    "mermaid": "^11.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "@anthropic-ai/sdk": "^0.74.0"
  }
}
